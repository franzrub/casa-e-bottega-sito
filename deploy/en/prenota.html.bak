<footer class="v2-footer" role="contentinfo">
  <div class="v2-container">
    <div class="v2-footer-grid">

      <!-- Brand -->
      <div>
        <div class="v2-footer-brand">Casa <em>e</em> Bottega</div>
        <p class="v2-footer-tagline" data-i18n="footer_desc">
          A due passi dal mare, nel cuore del Gargano.
          Una casa, due camere, una famiglia che vi apre la porta.
        </p>
