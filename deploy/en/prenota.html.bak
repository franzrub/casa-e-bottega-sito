<!-- ══ SCRIPTS ═════════════════════════════════════════════════════ -->
<script src="../js/i18n.min.js?v=20260428" defer></script>
<script src="../js/main.min.js?v=20260428" defer></script>
<script>
/* ============================================================
   v2 BOOKING MODAL CONTROLLER
   Runs before the IIFE below so _selectRoom can be overridden.
   ============================================================ */
(function() {
  'use strict';

  var currentStep = 1;
  var v2GuestsCount = 2;

  /* ── open / close ── */
  function openModal(step) {
    document.getElementById('v2-bm-overlay').classList.add('open');
    document.body.style.overflow = 'hidden';
    gotoStep(step || 1);
  }
  function closeModal() {
    document.getElementById('v2-bm-overlay').classList.remove('open');
    document.body.style.overflow = '';
  }

  /* ── step navigation ── */
  function gotoStep(n) {
    currentStep = n;
    // panels
    [1,2,3].forEach(function(i) {
      var el = document.getElementById('v2-step-' + i);
      if (el) el.classList.toggle('active', i === n);
    });
    // rail
    [1,2,3].forEach(function(i) {
      var rail = document.getElementById('rail-' + i);
      var circle = document.getElementById('rail-circle-' + i);
      if (!rail) return;
      rail.classList.remove('active','done');
      if (i === n) { rail.classList.add('active'); circle.textContent = i; }
      else if (i < n) {
        rail.classList.add('done');
        circle.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>';
      } else {
        circle.textContent = i;
      }
    });
    // back/next buttons
    var backBtn = document.getElementById('v2-bm-back');
    var nextBtn = document.getElementById('v2-bm-next');
    var navBar  = document.getElementById('v2-bm-nav');
    if (backBtn) backBtn.style.display = n > 1 ? 'block' : 'none';
    if (nextBtn) nextBtn.style.display = 'none'; // always hidden — each step has its own CTA
    // Step 1: nav bar hidden (CTA inside panel). Step 2: show back only. Step 3: hidden (submit inside form).
    if (navBar) navBar.style.display = (n === 2) ? 'flex' : 'none';
    // scroll to top of modal
    var card = document.querySelector('.v2-bm-card');
    if (card) card.scrollTop = 0;
    // render rooms on step 2
    if (n === 2) renderV2Rooms();
  }

  /* ── step 2: render room cards ── */
  function renderV2Rooms() {
    var grid = document.getElementById('v2-rooms-grid');
    if (!grid) return;
    var ci = document.getElementById('search-checkin').value;
    var co = document.getElementById('search-checkout').value;
    var _ROOMS = window.ROOMS;
    if (typeof _ROOMS === 'undefined' || !ci || !co) {
      grid.innerHTML = '<p style="font-family:Inter,sans-serif;color:var(--stone);padding:1rem;">' + (typeof t === 'function' ? t('book_select_dates') : 'Seleziona prima le date.') + '</p>';
      return;
    }
    var html = '';
    _ROOMS.forEach(function(room) {
      var avail = (typeof checkAvailability === 'function') ? checkAvailability(room.id, ci, co) : true;
      var pricing = (typeof calcPricing === 'function') ? calcPricing(room, ci, co) : null;
      var totalDirect = pricing ? pricing.totalDirect : '—';
      var totalOTA    = pricing ? pricing.totalOTA : null;
      var savings        = pricing ? pricing.savings : null;
      var discountLabel  = pricing ? pricing.discountLabel : '';
      var nights      = pricing ? pricing.nights : '—';
      var imgSrc      = room.id === 'dimora'
        ? '../foto-la-dimora/dimora-01-foto-principale.jpeg'
        : '../foto-la-bottega/bottega-01-foto%20principale.webp';
      var selectBtn = avail
        ? '<button class="v2-bm-select-btn" onclick="window._selectRoom(\'' + room.id + '\')">' +
          (typeof t === 'function' ? t('book_select') : 'Seleziona') + '</button>'
        : '<span class="v2-bm-room-unavail">' + (typeof t === 'function' ? t('book_unavailable') : 'Non disponibile in queste date') + '</span>';
      html += '<div class="v2-bm-room-card' + (avail ? '' : ' unavailable') + '">' +
        '<div class="v2-bm-room-img"><img src="' + imgSrc + '" alt="' + (typeof t === 'function' ? t(room.nameKey) : room.name) + '" loading="lazy"/></div>' +
        '<div class="v2-bm-room-body">' +
          '<div class="v2-bm-room-name">' + (typeof t === 'function' ? t(room.nameKey) : room.name) + '</div>' +
          '<div class="v2-bm-room-tagline">' + (typeof t === 'function' ? t(room.taglineKey) : room.tagline) + '</div>' +
          '<div class="v2-bm-room-pricing">' +
            '<div class="v2-bm-room-price-block">' +
              (totalOTA ? '<div class="v2-bm-room-ota">Booking: €' + totalOTA + '</div>' : '') +
              (discountLabel ? '<div class="v2-bm-room-discount-label">' + discountLabel + '</div>' : '') +
              '<div class="v2-bm-room-direct">€' + totalDirect + '</div>' +
              '<div class="v2-bm-room-direct-sub">' + nights + ' ' + (nights === 1 ? (typeof t === 'function' ? t('book_night') : 'notte') : (typeof t === 'function' ? t('book_nights') : 'notti')) + '</div>' +
              (savings ? '<div class="v2-bm-room-savings-badge">' + (typeof t === 'function' ? t('book_savings_badge') : 'risparmi €') + savings + '</div>' : '') +
            '</div>' +
            selectBtn +
          '</div>' +
        '</div>' +
      '</div>';
    });
    grid.innerHTML = html;
  }

  /* ── guests counter ── */
  function syncGuestsToInput() {
    var el = document.getElementById('search-guests');
    if (el) el.value = v2GuestsCount;
    var cnt = document.getElementById('v2-guests-count');
    if (cnt) cnt.textContent = v2GuestsCount;
  }

  /* ── display dates in stay panel ── */
  function updateStayPanel() {
    var ci = document.getElementById('search-checkin').value;
    var co = document.getElementById('search-checkout').value;
    var ciEl = document.getElementById('v2-display-checkin');
    var coEl = document.getElementById('v2-display-checkout');
    var nightsEl = document.getElementById('v2-display-nights');
    function fmtShort(s) {
      if (!s) return '—';
      var d = new Date(s);
      return d.toLocaleDateString('it-IT', { day:'numeric', month:'short' });
    }
    if (ciEl) ciEl.textContent = ci ? fmtShort(ci) : '—';
    if (coEl) coEl.textContent = co ? fmtShort(co) : '—';
    if (nightsEl) {
      if (ci && co) {
        var n = Math.ceil((new Date(co) - new Date(ci)) / 86400000);
        nightsEl.textContent = n;
      } else {
        nightsEl.textContent = '—';
      }
    }
  }

  /* ── wire CTAs ── */
  document.addEventListener('DOMContentLoaded', function() {
    var openBtn    = document.getElementById('v2-open-booking');
    var openBtn2   = document.getElementById('v2-open-booking-2');
    var openBtnNav = document.getElementById('v2-open-booking-nav');
    var closeBtn   = document.getElementById('v2-bm-close');
    var overlay  = document.getElementById('v2-bm-overlay');
    var backBtn  = document.getElementById('v2-bm-back');
    var nextBtn  = document.getElementById('v2-bm-next');

    if (openBtn)    openBtn.addEventListener('click',    function() { openModal(1); });
    if (openBtn2)   openBtn2.addEventListener('click',   function() { openModal(1); });
    if (openBtnNav) openBtnNav.addEventListener('click', function() { openModal(1); });
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    if (overlay)  overlay.addEventListener('click', function(e) { if (e.target === overlay) closeModal(); });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });

    // Back
    if (backBtn) backBtn.addEventListener('click', function() { gotoStep(currentStep - 1); });

    // Step 1 → 2 logic (shared by bottom next btn and panel CTA)
    function advanceStep1() {
      var ci = document.getElementById('search-checkin').value;
      var co = document.getElementById('search-checkout').value;
      var errEl = document.getElementById('v2-step1-error');
      if (!ci || !co || new Date(co) <= new Date(ci)) {
        if (errEl) errEl.classList.add('show');
        return;
      }
      if (errEl) errEl.classList.remove('show');
      gotoStep(2);
    }
    // Bottom nav Next
    if (nextBtn) nextBtn.addEventListener('click', function() {
      if (currentStep === 1) advanceStep1();
    });
    // Panel CTA inside stay panel
    var panelCta = document.getElementById('v2-step1-next-panel');
    if (panelCta) panelCta.addEventListener('click', advanceStep1);

    // Guests ± buttons
    var minusBtn = document.getElementById('v2-guests-minus');
    var plusBtn  = document.getElementById('v2-guests-plus');
    if (minusBtn) minusBtn.addEventListener('click', function() {
      if (v2GuestsCount > 1) { v2GuestsCount--; syncGuestsToInput(); }
    });
    if (plusBtn) plusBtn.addEventListener('click', function() {
      if (v2GuestsCount < 4) { v2GuestsCount++; syncGuestsToInput(); }
    });
    syncGuestsToInput();

    // Observe checkin/checkout changes (from calendar clicks) to update stay panel
    var ci = document.getElementById('search-checkin');
    var co = document.getElementById('search-checkout');
    if (ci) ci.addEventListener('change', updateStayPanel);
    if (co) co.addEventListener('change', updateStayPanel);

    // Payment option cards
    var payCards = document.querySelectorAll('.payment-option-card');
    var btnPaypal = document.getElementById('btn-submit-paypal');
    var btnOffline = document.getElementById('btn-submit-offline');
    payCards.forEach(function(card) {
      card.addEventListener('click', function() {
        payCards.forEach(function(c) { c.classList.remove('selected'); });
        card.classList.add('selected');
        var val = card.querySelector('input[type="radio"]').value;
        if (btnPaypal)  btnPaypal.classList.toggle('active',  val === 'paypal');
        if (btnOffline) btnOffline.classList.toggle('active', val === 'offline');
      });
    });

    // Sidebar confirm button — triggers form submission
    var btnSidebarConfirm = document.getElementById('btn-sidebar-confirm');
    if (btnSidebarConfirm) {
      btnSidebarConfirm.addEventListener('click', function() {
        var form = document.getElementById('booking-form');
        if (form) form.requestSubmit ? form.requestSubmit() : form.dispatchEvent(new Event('submit', { bubbles: true, cancelable: true }));
      });
    }

    // Sidebar back button — go back to step 2 (camera)
    var btnSidebarBack = document.getElementById('btn-sidebar-back');
    if (btnSidebarBack) {
      btnSidebarBack.addEventListener('click', function() {
        if (typeof window.v2GotoStep === 'function') window.v2GotoStep(2);
      });
    }

    // Also update stay panel when calendar renders (MutationObserver on cal-hint)
    var hint = document.getElementById('cal-hint');
    if (hint) {
      var mo = new MutationObserver(updateStayPanel);
      mo.observe(hint, { characterData: true, subtree: true, childList: true });
    }
  });

  /* ── expose openModal globally so other code can call it ── */
  window.v2OpenBooking = openModal;
  window.v2CloseBooking = closeModal;
  window.v2GotoStep = gotoStep;

  /* ── auto-open if URL contains ?open=1 ── */
  /* Use 'load' event (fires after defer scripts + images) to guarantee
     all listeners are wired and browser form-restore is complete */
  if (window.location.search.indexOf('open=1') !== -1) {
    window.addEventListener('load', function() {
      var ciEl = document.getElementById('search-checkin');
      var coEl = document.getElementById('search-checkout');
      if (ciEl) ciEl.value = '';
      if (coEl) coEl.value = '';
      // Small rAF delay to let any sync post-load code settle
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          openModal(1);
        });
      });
    });
  }

})();
</script>

<script>
  (function() {
    'use strict';

    /* ============================================
       ROOM DATA (source of truth for this page)
       ============================================ */
    const ROOMS = [
      {
        id: 'dimora',
        nameKey: 'room_dimora_name',
        name: 'La Dimora',
        taglineKey: 'room_dimora_tagline',
        tagline: 'Intima, silenziosa, ci si sente a casa',
        descKey: 'room_dimora_short',
        desc: 'Spaziosa, silenziosa, avvolta da luce morbida, la camera in cui ci si sente a casa.',
        image: '../foto-la-dimora/dimora-01-foto-principale.jpeg',
        extraBed: true,
        amenities: [],
        prices: { high: 100, low: 60 }
      },
      {
        id: 'bottega',
        nameKey: 'room_bottega_name',
        name: 'La Bottega',
        taglineKey: 'room_bottega_tagline',
        tagline: 'Curata nei dettagli, artigianale, ospitalità attesa',
        descKey: 'room_bottega_short',
        desc: 'Parete blu petrolio, cura dei dettagli, ospitalità attesa, il mare del Gargano senza mostrarlo.',
        image: '../foto-la-bottega/bottega-01-foto principale.webp',
        extraBed: false,
        amenities: [],
        prices: { high: 90, low: 50 }
      }
    ];

    let OTA_MARKUP = 1.25;
    let WEEKLY_DISCOUNT = 0.10;
    let MONTHLY_DISCOUNT = 0.20;

    const MONTH_KEYS = ['gennaio','febbraio','marzo','aprile','maggio','giugno',
                        'luglio','agosto','settembre','ottobre','novembre','dicembre'];

    let MESI_PREZZI = {
      gennaio:  { dimora: 60, bottega: 50 },
      febbraio: { dimora: 60, bottega: 50 },
      marzo:    { dimora: 60, bottega: 50 },
      aprile:   { dimora: 60, bottega: 50 },
      maggio:   { dimora: 60, bottega: 50 },
      giugno:   { dimora: 80, bottega: 74 },
      luglio:   { dimora: 100, bottega: 90 },
      agosto:   { dimora: 110, bottega: 100 },
      settembre:{ dimora: 110, bottega: 100 },
      ottobre:  { dimora: 60, bottega: 50 },
      novembre: { dimora: 60, bottega: 50 },
      dicembre: { dimora: 60, bottega: 50 }
    };

    fetch('/_data/prezzi.json')
      .then(r => r.ok ? r.json() : null)
      .then(data => {
        if (!data) return;
        OTA_MARKUP       = data.ota_markup       || OTA_MARKUP;
        WEEKLY_DISCOUNT  = data.weekly_discount  || WEEKLY_DISCOUNT;
        MONTHLY_DISCOUNT = data.monthly_discount || MONTHLY_DISCOUNT;
        if (data.mesi_prezzi) MESI_PREZZI = data.mesi_prezzi;
      })
      .catch(() => {});

    /* ============================================
       BOOKING STATE
       ============================================ */
    let state = {
      checkin: null,
      checkout: null,
      guests: 2,
      selectedRoom: null,
      nights: 0,
      totalDirect: 0,
      totalOTA: 0,
      discountLabel: ''
    };

    /* ============================================
       HELPERS
       ============================================ */
    function t(key) {
      const lang = localStorage.getItem('ceb_lang') || 'it';
      if (typeof translations === 'undefined') return key;
      const tr = translations[lang] || translations.it;
      return tr[key] || translations.it[key] || key;
    }

    function formatDate(dateStr) {
      const d = new Date(dateStr);
      return d.toLocaleDateString(document.documentElement.lang || 'it', {
        day: 'numeric', month: 'short', year: 'numeric'
      });
    }

    function getPrice(room, month) {
      var key  = MONTH_KEYS[month];
      var mese = MESI_PREZZI[key];
      if (mese && mese[room.id] != null) return mese[room.id];
      return room.prices ? (room.prices.high || room.prices.low || 60) : 60;
    }

    function calcPricing(room, checkinStr, checkoutStr) {
      const start = new Date(checkinStr);
      const end   = new Date(checkoutStr);
      const nights = Math.ceil((end - start) / (1000 * 60 * 60 * 24));
      if (nights <= 0) return null;
      let totalDirect = 0;
      for (let d = new Date(start); d < end; d.setDate(d.getDate() + 1)) {
        totalDirect += getPrice(room, d.getMonth());
      }
      let totalOTA = Math.round(totalDirect * OTA_MARKUP);
      let discountLabel = '';
      if (nights >= 7) {
        discountLabel = `-${Math.round(WEEKLY_DISCOUNT * 100)}% ${typeof t === 'function' ? t('price_weekly') : 'sconto settimanale'}`;
        totalDirect = Math.round(totalDirect * (1 - WEEKLY_DISCOUNT));
      }
      return { nights, totalDirect, totalOTA, savings: totalOTA - totalDirect, discountLabel };
    }

    function checkAvailability(roomId, checkinStr, checkoutStr) {
      if (typeof bookedDates === 'undefined') return true;
      const start = new Date(checkinStr);
      const end   = new Date(checkoutStr);
      for (let d = new Date(start); d < end; d.setDate(d.getDate() + 1)) {
        const ds = d.toISOString().slice(0, 10);
        if (bookedDates[roomId] && bookedDates[roomId].has(ds)) return false;
      }
      return true;
    }

    /* ============================================
       EXPOSE helpers for v2 modal controller
       ============================================ */
    window.calcPricing = calcPricing;
    window.checkAvailability = checkAvailability;
    window.ROOMS = ROOMS;

    /* ============================================
       ROOM SELECTION → step 3
       ============================================ */
    window._selectRoom = function(roomId) {
      const room = ROOMS.find(r => r.id === roomId);
      if (!room) return;

      const ci = document.getElementById('search-checkin').value;
      const co = document.getElementById('search-checkout').value;
      const pricing = calcPricing(room, ci, co);
      if (!pricing) return;

      state.checkin      = ci;
      state.checkout     = co;
      state.guests       = parseInt(document.getElementById('search-guests').value) || 2;
      state.selectedRoom = roomId;
      state.nights       = pricing.nights;
      state.totalDirect  = pricing.totalDirect;
      state.totalOTA     = pricing.totalOTA;
      state.discountLabel = pricing.discountLabel;

      // Fill step-3 summary sidebar
      const guestsCount = parseInt(document.getElementById('search-guests').value) || 2;
      const pricePerNight = pricing.nights > 0 ? Math.round(pricing.totalDirect / pricing.nights) : 0;
      document.getElementById('modal-room-name').textContent    = t(room.nameKey) || room.name;
      document.getElementById('modal-meta').textContent         = `${formatDate(ci)} → ${formatDate(co)} · ${pricing.nights} nott${pricing.nights === 1 ? 'e' : 'i'} · ${guestsCount} ospit${guestsCount === 1 ? 'e' : 'i'}`;
      document.getElementById('modal-rate-label').textContent   = `€${pricePerNight} × ${pricing.nights} nott${pricing.nights === 1 ? 'e' : 'i'}`;
      document.getElementById('modal-nights-total').textContent = `€${pricing.totalDirect}`;
      document.getElementById('modal-total-ota').textContent    = `€${pricing.totalOTA}`;
      var discountEl = document.getElementById('modal-discount-label');
      if (discountEl) {
        discountEl.textContent = pricing.discountLabel || '';
        discountEl.style.display = pricing.discountLabel ? '' : 'none';
      }
      document.getElementById('modal-total-direct').textContent = `€${pricing.totalDirect}`;
      document.getElementById('modal-savings').textContent      =
        (typeof t === 'function' ? t('book_you_save') : 'Risparmi') + ` €${pricing.savings} ` + (typeof t === 'function' ? t('book_savings_vs') : 'rispetto a Booking');

      // Show form, hide success
      document.getElementById('booking-form-section').style.display = 'block';
      document.getElementById('booking-success').classList.remove('active');

      // Advance to step 3
      if (typeof window.v2GotoStep === 'function') window.v2GotoStep(3);
    };

    // Close modal (also exposed via v2CloseBooking)
    document.getElementById('v2-bm-close').addEventListener('click', function() {
      if (typeof window.v2CloseBooking === 'function') window.v2CloseBooking();
    });

    /* ============================================
       FORM SUBMISSION
       ============================================ */
    document.getElementById('booking-form').addEventListener('submit', async function(e) {
      e.preventDefault();

      const name    = document.getElementById('guest-name').value.trim();
      const phone   = document.getElementById('guest-phone').value.trim();
      const email   = document.getElementById('guest-email').value.trim();
      const message = document.getElementById('guest-message').value.trim();
      const method  = document.querySelector('input[name="pay-method"]:checked').value;

      const phoneClean = phone.replace(/[\s\-\(\)]/g, '');
      if (!/^[+\d]{6,20}$/.test(phoneClean)) {
        document.getElementById('guest-phone').setCustomValidity('Inserisci un numero di telefono valido.');
        document.getElementById('guest-phone').reportValidity();
        return;
      }
      document.getElementById('guest-phone').setCustomValidity('');

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
      if (!emailRegex.test(email)) {
        document.getElementById('guest-email').setCustomValidity('Inserisci un indirizzo email valido.');
        document.getElementById('guest-email').reportValidity();
        return;
      }
      document.getElementById('guest-email').setCustomValidity('');

      const room = ROOMS.find(r => r.id === state.selectedRoom);
      const roomName = t(room.nameKey) || room.name;

      const submitBtn = document.querySelector('.v2-bm-submit-area button.active');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Invio in corso…';
      }
      const sidebarConfirmBtn = document.getElementById('btn-sidebar-confirm');
      if (sidebarConfirmBtn) {
        sidebarConfirmBtn.disabled = true;
        sidebarConfirmBtn.textContent = 'Invio in corso…';
      }

      try {
        await fetch('/.netlify/functions/send-booking', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            room: roomName,
            checkin: formatDate(state.checkin),
            checkout: formatDate(state.checkout),
            nights: state.nights,
            guests: state.guests,
            total: state.totalDirect,
            discount: state.discountLabel || '',
            name, phone, email, message, method
          })
        });
      } catch (err) {
        console.warn('[booking] send-booking error:', err.message);
      }

      showSuccess(method);
    });

    function showSuccess(method) {
      if (method === 'paypal') {
        document.getElementById('success-title').textContent = 'Richiesta inviata!';
        document.getElementById('success-message').innerHTML =
          'Abbiamo ricevuto la tua richiesta. Ti invieremo via email un <strong>link PayPal</strong> per completare il pagamento e confermare la prenotazione.';
      } else {
        document.getElementById('success-title').textContent = 'Richiesta inviata!';
        document.getElementById('success-message').innerHTML =
          'Abbiamo ricevuto la tua richiesta. Ti contatteremo entro <strong>24 ore</strong> per confermare la disponibilità e accordarci sul pagamento.';
      }
      document.getElementById('booking-form-section').style.display = 'none';
      document.getElementById('booking-success').classList.add('active');
      document.getElementById('booking-success').style.display = 'block';
    }

    /* ============================================
       MINI CALENDAR
       ============================================ */
    let miniCalMonth = new Date().getMonth();
    let miniCalYear  = new Date().getFullYear();
    let miniCalRoom  = 'dimora';
    let miniCalCheckin  = null;
    let miniCalCheckout = null;

    const checkinEl  = document.getElementById('search-checkin');
    const checkoutEl = document.getElementById('search-checkout');
    const guestsEl   = document.getElementById('search-guests');

    const _now = new Date();
    const _minCheckin = new Date(_now);
    if (_now.getHours() >= 21) _minCheckin.setDate(_minCheckin.getDate() + 1);
    const minCheckinStr = _minCheckin.toISOString().split('T')[0];
    checkinEl.min  = minCheckinStr;
    checkoutEl.min = minCheckinStr;

    function updateCalHint() {
      const hintEl = document.getElementById('cal-hint');
      if (!hintEl) return;
      const lang = localStorage.getItem('ceb_lang') || 'it';
      if (!miniCalCheckin && !miniCalCheckout) {
        hintEl.textContent = 'Clicca un giorno per impostare il check-in';
        hintEl.style.color = '';
      } else if (miniCalCheckin && !miniCalCheckout) {
        const d = new Date(miniCalCheckin);
        const fmt = d.toLocaleDateString('it-IT', { day: 'numeric', month: 'long' });
        hintEl.textContent = `Check-in: ${fmt} — ora clicca il giorno di check-out`;
        hintEl.style.color = 'var(--petrolio)';
      } else {
        const ci = new Date(miniCalCheckin);
        const co = new Date(miniCalCheckout);
        const nights = Math.ceil((co - ci) / (1000 * 60 * 60 * 24));
        const fmtCI = ci.toLocaleDateString('it-IT', { day: 'numeric', month: 'long' });
        const fmtCO = co.toLocaleDateString('it-IT', { day: 'numeric', month: 'long' });
        hintEl.textContent = `${fmtCI} → ${fmtCO} · ${nights} notti selezionate ✓`;
        hintEl.style.color = 'var(--petrolio)';
      }
    }

    function renderMiniCal() {
      const grid    = document.getElementById('mini-cal-grid');
      const titleEl = document.getElementById('mini-cal-title');
      if (!grid) return;

      if (checkinEl  && checkinEl.value  && !miniCalCheckin)  miniCalCheckin  = checkinEl.value;
      if (checkoutEl && checkoutEl.value && !miniCalCheckout) miniCalCheckout = checkoutEl.value;

      const lang = localStorage.getItem('ceb_lang') || 'it';
      const tr = (typeof translations !== 'undefined') ? (translations[lang] || translations.it) : null;

      titleEl.textContent = tr
        ? `${tr.cal_months[miniCalMonth]} ${miniCalYear}`
        : `${miniCalMonth + 1}/${miniCalYear}`;

      updateCalHint();

      let html = '';
      const dayNames = tr ? tr.cal_days : ['Lu','Ma','Me','Gi','Ve','Sa','Do'];
      dayNames.forEach(day => { html += `<div class="mini-cal-day-name">${day}</div>`; });

      const firstDay   = new Date(miniCalYear, miniCalMonth, 1).getDay();
      const startOffset = (firstDay + 6) % 7;
      for (let i = 0; i < startOffset; i++) html += '<div class="mini-cal-day empty"></div>';

      const daysInMonth = new Date(miniCalYear, miniCalMonth + 1, 0).getDate();
      const _nowCal = new Date();
      const _minCal = new Date(_nowCal);
      if (_nowCal.getHours() >= 21) _minCal.setDate(_minCal.getDate() + 1);
      const today = _minCal.toISOString().slice(0, 10);

      for (let d = 1; d <= daysInMonth; d++) {
        const ds = `${miniCalYear}-${String(miniCalMonth + 1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
        const isBooked   = (typeof bookedDates !== 'undefined') && bookedDates[miniCalRoom] && bookedDates[miniCalRoom].has(ds);
        const isPast     = ds < today;
        const isToday    = ds === today;
        const isDisabledBeforeCheckin = miniCalCheckin && !miniCalCheckout && ds <= miniCalCheckin;

        let cls = 'mini-cal-day';
        if (isPast || isBooked) {
          cls += ' booked';
        } else if (isDisabledBeforeCheckin) {
          cls += ' available cal-disabled-before-checkin';
        } else {
          cls += ' available';
          if (ds === miniCalCheckin)  cls += ' cal-checkin';
          else if (ds === miniCalCheckout) cls += ' cal-checkout';
          else if (miniCalCheckin && miniCalCheckout && ds > miniCalCheckin && ds < miniCalCheckout) cls += ' cal-range';
        }
        if (isToday) cls += ' today';

        const isClickable = !isPast && !isBooked && !isDisabledBeforeCheckin;
        const dataAttr    = isClickable ? ` data-date="${ds}"` : '';
        html += `<div class="${cls}"${dataAttr}>${d}</div>`;
      }

      grid.innerHTML = html;

      grid.querySelectorAll('.mini-cal-day.available[data-date]').forEach(dayEl => {
        dayEl.addEventListener('click', () => {
          const date = dayEl.dataset.date;
          if (!miniCalCheckin || (miniCalCheckin && miniCalCheckout)) {
            miniCalCheckin  = date;
            miniCalCheckout = null;
            if (checkinEl)  { checkinEl.value = miniCalCheckin; checkinEl.dispatchEvent(new Event('change')); }
            if (checkoutEl) { checkoutEl.value = ''; checkoutEl.dispatchEvent(new Event('change')); }
            if (checkinEl) {
              const maxCo = new Date(miniCalCheckin);
              maxCo.setDate(maxCo.getDate() + 29);
              checkoutEl.min = miniCalCheckin;
              checkoutEl.max = maxCo.toISOString().split('T')[0];
            }
          } else if (date > miniCalCheckin) {
            const nightsSel = Math.ceil((new Date(date) - new Date(miniCalCheckin)) / 86400000);
            if (nightsSel > 29) {
              const maxCo = new Date(miniCalCheckin);
              maxCo.setDate(maxCo.getDate() + 29);
              miniCalCheckout = maxCo.toISOString().slice(0, 10);
            } else {
              miniCalCheckout = date;
            }
            if (checkinEl)  { checkinEl.value  = miniCalCheckin;  checkinEl.dispatchEvent(new Event('change')); }
            if (checkoutEl) { checkoutEl.value = miniCalCheckout; checkoutEl.dispatchEvent(new Event('change')); }
          } else {
            miniCalCheckin  = date;
            miniCalCheckout = null;
            if (checkinEl)  { checkinEl.value = miniCalCheckin; checkinEl.dispatchEvent(new Event('change')); }
            if (checkoutEl) { checkoutEl.value = ''; checkoutEl.dispatchEvent(new Event('change')); }
          }
          renderMiniCal();
        });
      });
    }

    document.getElementById('mini-cal-prev').addEventListener('click', () => {
      miniCalMonth--;
      if (miniCalMonth < 0) { miniCalMonth = 11; miniCalYear--; }
      renderMiniCal();
    });
    document.getElementById('mini-cal-next').addEventListener('click', () => {
      miniCalMonth++;
      if (miniCalMonth > 11) { miniCalMonth = 0; miniCalYear++; }
      renderMiniCal();
    });
    document.querySelectorAll('.mini-cal-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.mini-cal-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        miniCalRoom = tab.dataset.room;
        renderMiniCal();
      });
    });

    renderMiniCal();

    document.addEventListener('calendarDataReady', () => { renderMiniCal(); });
    setTimeout(() => { renderMiniCal(); }, 8000);

  })();
</script>
</body>
</html>
