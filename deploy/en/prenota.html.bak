<!-- ══ HERO ════════════════════════════════════════════════════════ -->
<section class="pren-hero">
  <div class="v2-container">
    <div class="pren-hero-inner">
      <span class="pren-hero-label">Direct booking — no commission</span>
      <h1>Book<br/><em>your stay.</em></h1>
      <p class="pren-hero-sub">Three steps: dates, room, confirm. 20% less than Booking and Airbnb.</p>
      <div class="pren-hero-badges">
        <span class="pren-hero-badge"><strong>9,8</strong> / 10 Booking</span>
        <span class="pren-hero-badge">·</span>
        <span class="pren-hero-badge">Airbnb <strong>Superhost</strong></span>
        <span class="pren-hero-badge">·</span>
        <span class="pren-hero-badge"><strong>300 m</strong> dal mare</span>
      </div>
      <button class="v2-btn v2-btn--primary" id="v2-open-booking" style="font-size:12px; padding:16px 36px; letter-spacing:0.1em;">
        Start booking →
      </button>
    </div>
  </div>
</section>

<!-- ══ GUARANTEES ══════════════════════════════════════════════════ -->
<section class="pren-guarantees">
  <div class="v2-container">
    <span class="pren-section-label">Why book direct</span>
    <h2 class="pren-section-title">Our guarantees<br/><em style="font-style:italic; font-weight:300;">Casa e Bottega.</em></h2>
    <div class="pren-guarantees-grid">
      <div class="pren-guarantee-item">
        <svg class="pren-guarantee-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <div class="pren-guarantee-title">Secure payment</div>
        <p class="pren-guarantee-body">Certified PayPal or direct agreement with the owner. Your data doesn't pass through third-party platforms. Zero hidden fees.</p>
      </div>
      <div class="pren-guarantee-item">
        <svg class="pren-guarantee-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
        </svg>
        <div class="pren-guarantee-title">Direct support</div>
        <p class="pren-guarantee-body">Message Nicoletta on WhatsApp and get a reply within minutes — not hours. A real person who knows your room.</p>
      </div>
      <div class="pren-guarantee-item">
        <svg class="pren-guarantee-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/>
          <line x1="7" y1="7" x2="7.01" y2="7"/>
        </svg>
        <div class="pren-guarantee-title">Best price guaranteed</div>
        <p class="pren-guarantee-body">The direct price is always at least 20% less than Booking.com and Airbnb. If you find a lower price, we'll match it.</p>
      </div>
      <div class="pren-guarantee-item">
        <svg class="pren-guarantee-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <div class="pren-guarantee-title">Clear cancellation</div>
        <p class="pren-guarantee-body">Full refund if you cancel at least 30 days before arrival. No surprises, no hidden penalties.</p>
      </div>
    </div>
  </div>
</section>

<!-- ══ COME FUNZIONA ═══════════════════════════════════════════════ -->
<section class="pren-how">
  <div class="v2-container">
    <span class="pren-section-label">The process</span>
    <h2 class="pren-section-title">How it works</h2>
    <div class="pren-how-steps">
      <div class="pren-how-step">
        <div class="pren-how-num">01</div>
        <div class="pren-how-step-title">Choose your dates</div>
        <p class="pren-how-step-body">Open the calendar, click your arrival date then departure. Occupied days are crossed out — only free dates are clickable. You can also select a room to check availability.</p>
      </div>
      <div class="pren-how-step">
        <div class="pren-how-num">02</div>
        <div class="pren-how-step-title">Choose your room</div>
        <p class="pren-how-step-body">See rooms available for your dates with the direct price and comparison with Booking and Airbnb. Choose the one for you — La Dimora or La Bottega.</p>
      </div>
      <div class="pren-how-step">
        <div class="pren-how-num">03</div>
        <div class="pren-how-step-title">Confirm and pay</div>
        <p class="pren-how-step-body">Enter your details, choose payment method (PayPal or direct with host) and submit. Receive confirmation within a few hours — or message Nicoletta on WhatsApp if you prefer to speak to a person.</p>
      </div>
    </div>
    <div style="margin-top: 3rem; text-align: center;">
      <button class="v2-btn v2-btn--primary" id="v2-open-booking-2" style="font-size:12px; padding:16px 36px; letter-spacing:0.1em;">
        Start booking →
      </button>
    </div>
  </div>
</section>

<!-- ══ HIDDEN INPUTS (JS compatibility) ═══════════════════════════ -->
<input id="search-checkin" type="date" aria-hidden="true"/>
<input id="search-checkout" type="date" aria-hidden="true"/>
<select id="search-guests" aria-hidden="true">
  <option value="1">1</option>
  <option value="2" selected>2</option>
</select>
<div id="max-nights-error" aria-hidden="true"></div>

<!-- ══ BOOKING MODAL v2 ════════════════════════════════════════════ -->
<div class="v2-bm-overlay" id="v2-bm-overlay" role="dialog" aria-modal="true" aria-label="Prenotazione">
  <div class="v2-bm-card">

    <!-- Header -->
    <div class="v2-bm-header">
      <span class="v2-bm-header-title">Book your stay</span>
      <button class="v2-bm-close" id="v2-bm-close" aria-label="Close">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Step rail -->
    <div class="v2-bm-rail">
      <div class="v2-bm-rail-step active" id="rail-1">
        <div class="v2-bm-rail-circle" id="rail-circle-1">1</div>
        <div class="v2-bm-rail-label-wrap">
          <span class="v2-bm-rail-sublabel">Step 01</span>
          <span class="v2-bm-rail-label">Dates</span>
        </div>
      </div>
      <div class="v2-bm-rail-step" id="rail-2">
        <div class="v2-bm-rail-circle" id="rail-circle-2">2</div>
        <div class="v2-bm-rail-label-wrap">
          <span class="v2-bm-rail-sublabel">Step 02</span>
          <span class="v2-bm-rail-label">Room</span>
        </div>
      </div>
      <div class="v2-bm-rail-step" id="rail-3">
        <div class="v2-bm-rail-circle" id="rail-circle-3">3</div>
        <div class="v2-bm-rail-label-wrap">
          <span class="v2-bm-rail-sublabel">Step 03</span>
          <span class="v2-bm-rail-label">Details</span>
        </div>
      </div>
    </div>

    <!-- ─── STEP 1: DATE ──────────────────────────────────────────── -->
    <div class="v2-bm-step active v2-bm-body" id="v2-step-1">
      <div class="v2-bm-step1-grid">

        <!-- Calendar (no tabs — tabs are in step 2) -->
        <div class="v2-bm-cal-wrap">
          <span class="v2-bm-cal-section-label">Choose your dates</span>
          <!-- hidden tabs kept for JS compat -->
          <div class="mini-cal-tabs" style="display:none">
            <button class="mini-cal-tab active" data-room="dimora">La Dimora</button>
            <button class="mini-cal-tab" data-room="bottega">La Bottega</button>
          </div>
          <div class="cal-selection-hint" id="cal-hint">Click a day to set check-in</div>
          <div class="mini-cal-header">
            <button class="mini-cal-nav" id="mini-cal-prev">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <span id="mini-cal-title">Aprile 2026</span>
            <button class="mini-cal-nav" id="mini-cal-next">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
          <div class="mini-cal-grid" id="mini-cal-grid"></div>
          <div class="mini-cal-legend">
            <span><span class="mini-cal-legend-dot avail"></span><span data-i18n="cal_available">Disponibile</span></span>
            <span><span class="mini-cal-legend-dot booked"></span><span data-i18n="cal_booked">Occupato</span></span>
          </div>
        </div>

        <!-- Stay summary panel (light) -->
        <div class="v2-bm-stay-panel">
          <span class="v2-bm-stay-label">Your stay</span>
          <div class="v2-bm-date-row">
            <div class="v2-bm-date-box">
              <span class="v2-bm-date-box-lbl">Check-in</span>
              <span class="v2-bm-date-box-val" id="v2-display-checkin">—</span>
              <span class="v2-bm-date-box-sub" id="v2-sub-checkin">from 15:00</span>
            </div>
            <div class="v2-bm-date-box">
              <span class="v2-bm-date-box-lbl">Check-out</span>
              <span class="v2-bm-date-box-val" id="v2-display-checkout">—</span>
              <span class="v2-bm-date-box-sub" id="v2-sub-checkout">by 11:00</span>
            </div>
          </div>
          <div class="v2-bm-nights-row">
            <span class="v2-bm-nights-label">Nights</span>
            <span class="v2-bm-nights-val" id="v2-display-nights">—</span>
          </div>
          <div class="v2-bm-guests-row">
            <span class="v2-bm-guests-lbl">Guests</span>
            <div class="v2-bm-guests-ctrl">
              <button class="v2-bm-guests-btn" id="v2-guests-minus" aria-label="Reduce guests">−</button>
              <span class="v2-bm-guests-count" id="v2-guests-count">2</span>
              <button class="v2-bm-guests-btn" id="v2-guests-plus" aria-label="Add guests">+</button>
              <span class="v2-bm-guests-word">guests</span>
            </div>
          </div>
          <p id="v2-step1-error" class="v2-bm-error-panel">Select check-in and check-out to continue.</p>
          <button class="v2-bm-stay-cta" id="v2-step1-next-panel" data-i18n="book_next_step">
            Avanti: scegli camera →
          </button>
          <p class="v2-bm-stay-note"><span data-i18n="book_stay_max">Soggiorno massimo 29 giorni (locazione turistica). Per soggiorni più lunghi</span> <a href="contatti.html" style="color:var(--petrolio)" data-i18n="book_contact_us">contattaci</a>.</p>
        </div>

      </div>
    </div>

    <!-- ─── STEP 2: CAMERA ────────────────────────────────────────── -->
    <div class="v2-bm-step v2-bm-body" id="v2-step-2">
      <div class="v2-bm-rooms-grid" id="v2-rooms-grid">
        <!-- injected by JS -->
      </div>
    </div>

    <!-- ─── STEP 3: DATI ──────────────────────────────────────────── -->
    <div class="v2-bm-step v2-bm-body" id="v2-step-3">
      <div id="booking-form-section">
        <div class="v2-bm-step3-grid">

          <!-- Form -->
          <div class="v2-bm-form-side">
            <form class="v2-modal-form" id="booking-form">
              <p style="font-family:'JetBrains Mono',monospace; font-size:0.6rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--stone); margin:0 0 1.2rem; opacity:0.7;" data-i18n="book_your_data">I tuoi dati</p>
              <div class="form-row">
                <div class="form-group">
                  <label class="required" data-i18n="book_name" for="guest-name">Nome e Cognome</label>
                  <input id="guest-name" name="name" required type="text" autocomplete="name" placeholder="Maria Rossi"/>
                </div>
                <div class="form-group">
                  <label class="required" data-i18n="book_phone" for="guest-phone">Telefono · WhatsApp</label>
                  <input id="guest-phone" inputmode="numeric" name="phone" required type="tel" autocomplete="tel" placeholder="+39 333 000 0000"/>
                </div>
              </div>
              <div class="form-group">
                <label class="required" data-i18n="book_email" for="guest-email">Email</label>
                <input id="guest-email" name="email" required type="email" autocomplete="email" placeholder="tu@email.it"/>
              </div>
              <div class="form-group">
                <label data-i18n="book_message" for="guest-message">Note o richieste (opzionale)</label>
                <textarea id="guest-message" name="message" placeholder="Arrivo in tarda serata, consigli per ristoranti…"></textarea>
              </div>

              <!-- Payment -->
              <div class="v2-payment-section">
                <span class="v2-payment-label" data-i18n="book_payment_title">Metodo di pagamento</span>
                <div class="payment-cards-grid">
                  <label class="payment-option-card selected" id="pay-card-paypal">
                    <input checked name="pay-method" type="radio" value="paypal"/>
                    <div class="pay-card-inner">
                      <div class="pay-card-text">
                        <div class="pay-title" data-i18n="book_pay_paypal">PayPal</div>
                        <div class="pay-desc" data-i18n="book_pay_paypal_desc">Pagamento sicuro online</div>
                      </div>
                      <svg class="pay-check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                  </label>
                  <label class="payment-option-card" id="pay-card-offline">
                    <input name="pay-method" type="radio" value="offline"/>
                    <div class="pay-card-inner">
                      <div class="pay-card-text">
                        <div class="pay-title" data-i18n="book_pay_offline">Offline</div>
                        <div class="pay-desc" data-i18n="book_pay_offline_desc">Bonifico · accordo diretto</div>
                      </div>
                      <svg class="pay-check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                  </label>
                </div>
              </div>

              <!-- Cancellation note -->
              <div class="v2-cancel-note" style="margin-top:1.2rem;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" style="flex-shrink:0; margin-top:1px"><circle cx="12" cy="12" r="10"/></svg>
                <span data-i18n="book_cancel_policy">Rimborso totale se cancelli almeno 30 giorni prima dell'arrivo. Nessuna penale nascosta.</span>
              </div>

              <!-- Submit (hidden — button lives in sidebar) -->
              <div class="v2-bm-submit-area">
                <button class="btn-book-paypal active" data-i18n="book_send_paypal" id="btn-submit-paypal" type="submit">Procedi al pagamento PayPal</button>
                <button class="btn-book-offline" data-i18n="book_send_offline" id="btn-submit-offline" type="submit">Completa prenotazione</button>
              </div>
            </form>
          </div>

          <!-- Summary sidebar -->
          <div class="v2-bm-summary-side">
            <span class="v2-bm-summary-overtitle">Summary</span>
            <div class="v2-bm-summary-room" id="modal-room-name">—</div>
            <div class="v2-bm-summary-meta" id="modal-meta">—</div>
            <div class="v2-bm-summary-line">
              <span id="modal-rate-label">—</span>
              <span id="modal-nights-total">—</span>
            </div>

            <div class="v2-bm-summary-total">
              <div class="v2-bm-summary-total-label">Total</div>
              <div class="v2-bm-summary-ota" id="modal-total-ota"></div>
              <div class="v2-bm-summary-discount" id="modal-discount-label"></div>
              <div class="v2-bm-summary-direct" id="modal-total-direct">—</div>
              <span class="v2-bm-summary-savings" id="modal-savings"></span>
            </div>
            <!-- Sidebar CTA -->
            <div class="v2-bm-sidebar-cta">
              <button class="btn-sidebar-confirm" id="btn-sidebar-confirm" type="button">
                CONFERMA RICHIESTA
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>
              <button class="btn-sidebar-back" id="btn-sidebar-back" type="button">← Back to room</button>
            </div>
          </div>

        </div>
      </div>

      <!-- Success -->
      <div class="booking-success-msg" id="booking-success">
        <div class="success-icon">✓</div>
        <h3 data-i18n="book_success_title" id="success-title">Richiesta inviata!</h3>
        <p data-i18n="book_success_msg" id="success-message">Riceverai una conferma via email entro poche ore. Per qualsiasi necessità siamo subito disponibili su WhatsApp.</p>
        <a class="btn-success-wa" href="https://wa.me/393334705574?text=Ciao%2C%20ho%20appena%20inviato%20una%20richiesta%20di%20prenotazione%20dal%20sito.">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span data-i18n="book_success_wa">Scrivici su WhatsApp</span>
        </a>
        <a class="v2-btn" data-i18n="book_back_home" href="index.html" style="display:inline-block; margin-top:0.5rem; width:100%; max-width:340px; text-align:center; text-decoration:none; background:transparent; border:1px solid rgba(154,143,128,0.5); color:var(--ink);">Torna alla home</a>
      </div>
    </div>

    <!-- Modal nav bar (bottom) -->
    <div class="v2-bm-nav" id="v2-bm-nav">
      <a class="v2-bm-nav-wa" href="https://wa.me/393334705574?text=Ciao!%20Vorrei%20prenotare%20Casa%20e%20Bottega." target="_blank" rel="noopener">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <span data-i18n="book_wa_cta">Prenota via WhatsApp</span>
      </a>
      <div style="display:flex; gap:0.6rem; align-items:center;">
        <button class="v2-bm-nav-back" id="v2-bm-back" style="display:none;">← Back</button>
