<style>
/* ============================================================
   PRENOTA v2 — page-specific styles
   ============================================================ */

/* ── Hero ─────────────────────────────────────────────── */
.pren-hero {
  background: var(--bone);
  color: var(--ink);
  padding: 8rem 0 6rem;
  position: relative;
  overflow: hidden;
  text-align: center;
}
.pren-hero-inner {
  position: relative;
  max-width: 820px;
  margin: 0 auto;
}
.pren-hero-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.85rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--terracotta);
  margin-bottom: 1.6rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}
.pren-hero-label::before { content: none; }
.pren-hero h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(3.2rem, 7vw, 6rem);
  font-weight: 300;
  line-height: 0.95;
  letter-spacing: -0.02em;
  color: var(--ink);
  margin-bottom: 2rem;
}
.pren-hero h1 em {
  font-style: italic;
  color: var(--terracotta);
}
.pren-hero-sub {
  font-family: 'Inter', sans-serif;
  font-size: 1.05rem;
  line-height: 1.7;
  color: var(--stone);
  max-width: 520px;
  margin: 0 auto 2.8rem;
}
.pren-hero-badges {
  display: flex;
  gap: 1.2rem;
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: 3rem;
}
.pren-hero-badge {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  color: var(--stone);
  text-transform: uppercase;
}
.pren-hero-badge strong {
  color: var(--ink);
  font-weight: 500;
}

/* ── Guarantees ───────────────────────────────────────── */
.pren-guarantees {
  background: var(--paper);
  padding: 4.5rem 0;
}
.pren-guarantees-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
  margin-top: 2.8rem;
}
.pren-guarantee-item {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}
.pren-guarantee-icon {
  width: 36px;
  height: 36px;
  color: var(--petrolio);
  flex-shrink: 0;
}
.pren-guarantee-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--ink);
  letter-spacing: 0.01em;
}
.pren-guarantee-body {
  font-family: 'Inter', sans-serif;
  font-size: 0.88rem;
  line-height: 1.65;
  color: var(--stone);
}

/* ── Come funziona ────────────────────────────────────── */
.pren-how {
  background: var(--bone);
  padding: 5rem 0;
}
.pren-how-steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 3rem;
  margin-top: 3rem;
}
.pren-how-step {
  position: relative;
}
.pren-how-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 5rem;
  font-weight: 300;
  font-style: italic;
  color: var(--terracotta);
  line-height: 1;
  opacity: 0.35;
  margin-bottom: 0.6rem;
}
.pren-how-step-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.35rem;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 0.6rem;
}
.pren-how-step-body {
  font-family: 'Inter', sans-serif;
  font-size: 0.88rem;
  line-height: 1.7;
  color: var(--stone);
}

/* ── Section header (shared) ──────────────────────────── */
.pren-section-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--terracotta);
  margin-bottom: 0.8rem;
  display: block;
}
.pren-section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(1.8rem, 3vw, 2.4rem);
  font-weight: 300;
  line-height: 1.1;
  color: var(--ink);
  letter-spacing: -0.01em;
}

/* ══════════════════════════════════════════════════════
   3-STEP BOOKING MODAL
   ══════════════════════════════════════════════════════ */
.v2-bm-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 300;
  background: rgba(26,22,19,0.88);
  align-items: center;
  justify-content: center;
  padding: 1rem;
}
.v2-bm-overlay.open {
  display: flex;
}
.v2-bm-card {
  background: var(--bone);
  width: 100%;
  max-width: 940px;
  max-height: 92vh;
  overflow-y: auto;
  border-radius: 4px;
  position: relative;
  display: flex;
  flex-direction: column;
}
.v2-bm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.8rem 2rem 1.2rem;
  border-bottom: 1px solid rgba(154,143,128,0.2);
  position: sticky;
  top: 0;
  background: var(--bone);
  z-index: 10;
}
.v2-bm-header-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.4rem;
  font-weight: 400;
  font-style: italic;
  color: var(--ink);
  letter-spacing: 0.01em;
}
.v2-bm-close {
  width: 32px;
  height: 32px;
  border: 1px solid rgba(154,143,128,0.4);
  background: none;
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--stone);
  font-size: 1.1rem;
  transition: border-color 0.2s, color 0.2s;
}
.v2-bm-close:hover {
  border-color: var(--ink);
  color: var(--ink);
}

/* Step rail */
.v2-bm-rail {
  display: flex;
  align-items: center;
  gap: 0;
  padding: 1.4rem 2rem;
  border-bottom: 1px solid rgba(154,143,128,0.15);
  background: var(--paper);
}
.v2-bm-rail-step {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex: 1;
}
.v2-bm-rail-step:not(:last-child)::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(154,143,128,0.3);
  margin: 0 1rem;
}
.v2-bm-rail-circle {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 1.5px solid rgba(154,143,128,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  color: var(--stone);
  flex-shrink: 0;
  transition: all 0.25s;
}
.v2-bm-rail-step.active .v2-bm-rail-circle {
  background: var(--ink);
  border-color: var(--ink);
  color: var(--bone);
}
.v2-bm-rail-step.done .v2-bm-rail-circle {
  background: var(--petrolio);
  border-color: var(--petrolio);
  color: var(--bone);
}
.v2-bm-rail-step.done:not(:last-child)::after {
  background: var(--petrolio);
  opacity: 0.55;
}
.v2-bm-rail-label-wrap {
  display: flex;
  flex-direction: column;
  gap: 1px;
}
.v2-bm-rail-sublabel {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--stone);
  opacity: 0.6;
}
.v2-bm-rail-step.active .v2-bm-rail-sublabel {
  opacity: 1;
  color: var(--stone);
}
.v2-bm-rail-label {
  font-family: 'Inter', sans-serif;
  font-size: 0.88rem;
  font-weight: 500;
  color: var(--stone);
  white-space: nowrap;
}
.v2-bm-rail-step.active .v2-bm-rail-label {
  color: var(--ink);
  font-weight: 600;
}
.v2-bm-rail-step.done .v2-bm-rail-label {
  color: var(--petrolio);
}
.v2-bm-rail-step.done .v2-bm-rail-sublabel {
  opacity: 1;
  color: var(--petrolio);
}

/* Step panels */
.v2-bm-step { display: none; }
.v2-bm-step.active { display: block; }
.v2-bm-body { padding: 2rem; }

/* ── Step 1: Date ─────────────────────────────────────── */
.v2-bm-step1-grid {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 2.5rem;
  align-items: start;
}
.v2-bm-cal-wrap {
  background: transparent;
  border-radius: 0;
  padding: 0;
}
.v2-bm-cal-section-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--stone);
  margin-bottom: 1.6rem;
  display: block;
}
.v2-bm-stay-panel {
  background: var(--paper);
  color: var(--ink);
  border-radius: 3px;
  padding: 0;
  position: sticky;
  top: 120px;
  border: 1px solid rgba(154,143,128,0.2);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.v2-bm-stay-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--stone);
  display: block;
  padding: 1.4rem 1.4rem 0;
}
.v2-bm-date-row {
  display: flex;
  gap: 0;
  margin: 1rem 0 0;
  border-top: 1px solid rgba(154,143,128,0.15);
  border-bottom: 1px solid rgba(154,143,128,0.15);
}
.v2-bm-date-box {
  flex: 1;
  padding: 1.1rem 1.4rem;
}
.v2-bm-date-box:first-child {
  border-right: 1px solid rgba(154,143,128,0.15);
}
.v2-bm-date-box-lbl {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--stone);
  margin-bottom: 0.4rem;
  display: block;
}
.v2-bm-date-box-val {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.9rem;
  font-weight: 300;
  color: var(--ink);
  line-height: 1;
  display: block;
  margin-bottom: 0.2rem;
}
.v2-bm-date-box-sub {
  font-family: 'Inter', sans-serif;
  font-size: 0.72rem;
  color: var(--stone);
  display: block;
}
.v2-bm-nights-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 1rem 1.4rem;
  border-bottom: 1px solid rgba(154,143,128,0.15);
}
.v2-bm-nights-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--stone);
}
.v2-bm-nights-val {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.2rem;
  font-weight: 300;
  color: var(--ink);
  line-height: 1;
}
.v2-bm-guests-row {
  padding: 1rem 1.4rem 0;
}
.v2-bm-guests-lbl {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--stone);
  margin-bottom: 0.7rem;
  display: block;
}
.v2-bm-guests-ctrl {
  display: flex;
  align-items: center;
  gap: 1rem;
}
.v2-bm-guests-btn {
  width: 36px;
  height: 36px;
  border: 1px solid rgba(154,143,128,0.4);
  background: none;
  color: var(--ink);
  border-radius: 50%;
  cursor: pointer;
  font-size: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s, border-color 0.15s;
}
.v2-bm-guests-btn:hover {
  background: var(--ink);
  color: var(--bone);
  border-color: var(--ink);
}
.v2-bm-guests-count {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.8rem;
  font-weight: 300;
  color: var(--ink);
  min-width: 2rem;
  text-align: center;
}
.v2-bm-guests-word {
  font-family: 'Inter', sans-serif;
  font-size: 0.82rem;
  color: var(--stone);
}
.v2-bm-stay-cta {
  margin: 1.4rem 1.4rem 1.4rem;
  width: calc(100% - 2.8rem);
  padding: 1rem;
  background: var(--ink);
  color: var(--bone);
  border: none;
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  border-radius: 2px;
  transition: background 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
}
.v2-bm-stay-cta:hover { background: var(--petrolio); }
.v2-bm-stay-cta:disabled { opacity: 0.35; cursor: not-allowed; background: var(--stone); }
.v2-bm-stay-note {
  font-family: 'Inter', sans-serif;
  font-size: 0.72rem;
  color: var(--stone);
  padding: 0 1.4rem 1.2rem;
  line-height: 1.5;
}
.v2-bm-error-panel {
  padding: 0 1.4rem;
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  color: var(--terracotta);
  display: none;
}
.v2-bm-error-panel.show { display: block; }

/* calendar restyled inside modal — tabs hidden in step 1, shown only in step 2 */
.v2-bm-cal-wrap .mini-cal-tabs {
  display: none; /* hidden: room tabs live in step 2, not step 1 */
}
.v2-bm-cal-wrap .mini-cal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.2rem;
}
.v2-bm-cal-wrap .mini-cal-header span {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.5rem;
  font-style: italic;
  font-weight: 400;
  color: var(--ink);
  letter-spacing: -0.01em;
}
.v2-bm-cal-wrap .mini-cal-nav {
  width: 36px; height: 36px;
  border: 1px solid rgba(154,143,128,0.35);
  border-radius: 50%;
  background: none;
  color: var(--stone);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: border-color 0.2s, color 0.2s;
}
.v2-bm-cal-wrap .mini-cal-nav:hover {
  border-color: var(--ink);
  color: var(--ink);
}
.v2-bm-cal-wrap .mini-cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 2px;
}
.v2-bm-cal-wrap .mini-cal-day {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Inter', sans-serif;
  font-size: 0.9rem;
  cursor: default;
  min-height: 46px;
  border-radius: 2px;
  transition: background 0.12s, color 0.12s;
}
.v2-bm-cal-wrap .mini-cal-day-name {
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Inter', sans-serif;
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--stone);
  padding-bottom: 0.5rem;
  min-height: 32px;
  text-transform: uppercase;
}
.v2-bm-cal-wrap .mini-cal-day.available {
  cursor: pointer;
  color: var(--ink);
  background: none;
}
.v2-bm-cal-wrap .mini-cal-day.available:hover {
  background: rgba(26,22,19,0.07);
  color: var(--ink);
}
.v2-bm-cal-wrap .mini-cal-day.booked {
  color: rgba(154,143,128,0.35);
  text-decoration: line-through;
  background: none;
}
.v2-bm-cal-wrap .mini-cal-day.empty {
  background: none;
}
.v2-bm-cal-wrap .mini-cal-day.cal-checkin,
.v2-bm-cal-wrap .mini-cal-day.cal-checkout {
  background: var(--ink) !important;
  color: var(--bone) !important;
  font-weight: 600;
  border-radius: 2px;
}
.v2-bm-cal-wrap .mini-cal-day.cal-range {
  background: var(--paper) !important;
  color: var(--ink) !important;
  border-radius: 0;
}
.v2-bm-cal-wrap .mini-cal-day.today::after {
  content: '';
  position: absolute;
  bottom: 4px;
  left: 50%;
  transform: translateX(-50%);
  width: 4px; height: 4px;
  background: var(--terracotta);
  border-radius: 50%;
}
.v2-bm-cal-wrap .mini-cal-day.today { position: relative; }
.v2-bm-cal-wrap .mini-cal-day.cal-disabled-before-checkin {
  opacity: 0.25;
  cursor: not-allowed;
  background: none;
}
.v2-bm-cal-wrap .mini-cal-legend {
  display: flex;
  gap: 1.4rem;
  margin-top: 1rem;
  font-family: 'Inter', sans-serif;
  font-size: 0.72rem;
  color: var(--stone);
}
.v2-bm-cal-wrap .mini-cal-legend span {
  display: flex;
  align-items: center;
  gap: 0.4rem;
}
.v2-bm-cal-wrap .mini-cal-legend-dot {
  width: 12px; height: 12px;
  border-radius: 2px;
  display: inline-block;
}
.v2-bm-cal-wrap .mini-cal-legend-dot.avail {
  background: rgba(26,22,19,0.08);
  border: 1px solid rgba(154,143,128,0.3);
}
.v2-bm-cal-wrap .mini-cal-legend-dot.booked {
  background: rgba(154,143,128,0.2);
}
.v2-bm-cal-wrap .cal-selection-hint {
  font-family: 'Inter', sans-serif;
  font-size: 0.82rem;
  color: var(--stone);
  margin-bottom: 1rem;
  min-height: 1.2em;
  font-style: italic;
}

/* ── Step 2: Camera ───────────────────────────────────── */
.v2-bm-rooms-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}
.v2-bm-room-card {
  border: 1px solid rgba(154,143,128,0.2);
  border-radius: 3px;
  overflow: hidden;
  background: var(--paper);
  cursor: pointer;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.v2-bm-room-card:hover {
  border-color: var(--petrolio);
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}
.v2-bm-room-img {
  aspect-ratio: 4/3;
  overflow: hidden;
}
.v2-bm-room-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.v2-bm-room-card:hover .v2-bm-room-img img {
  transform: scale(1.04);
}
.v2-bm-room-body {
  padding: 1.2rem;
}
.v2-bm-room-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.3rem;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 0.25rem;
}
.v2-bm-room-tagline {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 0.9rem;
  color: var(--stone);
  margin-bottom: 0.9rem;
}
.v2-bm-room-pricing {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 0.8rem;
  padding-top: 0.8rem;
  border-top: 1px solid rgba(154,143,128,0.15);
}
.v2-bm-room-price-block {}
.v2-bm-room-ota {
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  color: var(--stone);
  text-decoration: line-through;
  opacity: 0.7;
}
.v2-bm-room-direct {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.6rem;
  font-weight: 600;
  color: var(--petrolio);
  line-height: 1;
}
.v2-bm-room-direct-sub {
  font-family: 'Inter', sans-serif;
  font-size: 0.72rem;
  color: var(--stone);
}
.v2-bm-room-savings-badge {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  color: var(--petrolio);
  background: rgba(31,74,74,0.1);
  padding: 0.2rem 0.5rem;
  border-radius: 2px;
  white-space: nowrap;
}
.v2-bm-room-discount-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.68rem;
  color: var(--petrolio);
  background: rgba(31,74,74,0.1);
  padding: 0.15rem 0.45rem;
  border-radius: 2px;
  white-space: nowrap;
  margin-bottom: 0.15rem;
  display: inline-block;
}
.v2-bm-room-unavail {
  font-family: 'Inter', sans-serif;
  font-size: 0.82rem;
  color: var(--terracotta);
  opacity: 0.8;
  padding: 0.4rem 0;
}
.v2-bm-select-btn {
  font-family: 'Inter', sans-serif;
  font-size: 0.82rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  padding: 0.6rem 1.2rem;
  background: var(--ink);
  color: var(--bone);
  border: none;
  border-radius: 2px;
  cursor: pointer;
  transition: background 0.2s;
  white-space: nowrap;
  flex-shrink: 0;
}
.v2-bm-select-btn:hover { background: var(--petrolio); }
.v2-bm-select-btn:disabled {
  opacity: 0.35;
  cursor: not-allowed;
  background: var(--stone);
}

/* ── Step 3: Dati ─────────────────────────────────────── */
.v2-bm-step3-grid {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 2rem;
  align-items: start;
}
.v2-bm-form-side {}
.v2-bm-summary-side {
  background: var(--ink);
  color: var(--bone);
  border-radius: 3px;
  padding: 1.6rem;
  position: sticky;
  top: 120px;
  display: flex;
  flex-direction: column;
}
/* RIEPILOGO over-title */
.v2-bm-summary-overtitle {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(245,239,230,0.45);
  margin-bottom: 0.5rem;
  display: block;
}
.v2-bm-summary-room {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.55rem;
  font-weight: 500;
  font-style: italic;
  color: var(--bone);
  margin-bottom: 0.3rem;
  line-height: 1.15;
}
/* meta: dates · nights · guests */
.v2-bm-summary-meta {
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  color: rgba(245,239,230,0.5);
  margin-bottom: 1.1rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid rgba(245,239,230,0.1);
  line-height: 1.5;
}
.v2-bm-summary-line {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  font-family: 'Inter', sans-serif;
  font-size: 0.82rem;
  color: rgba(245,239,230,0.6);
  margin-bottom: 0.6rem;
}
.v2-bm-summary-line span:last-child {
  color: var(--bone);
  font-weight: 500;
  text-align: right;
}
.v2-bm-summary-total {
  border-top: 1px solid rgba(245,239,230,0.12);
  margin-top: 1rem;
  padding-top: 1rem;
}
.v2-bm-summary-total-label {
  font-family: 'Inter', sans-serif;
  font-size: 0.82rem;
  color: rgba(245,239,230,0.6);
  margin-bottom: 0.3rem;
}
.v2-bm-summary-ota {
  display: none; /* hidden — savings shown below price instead */
}
.v2-bm-summary-direct {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.4rem;
  font-weight: 300;
  color: var(--bone);
  line-height: 1;
  margin-bottom: 0.25rem;
}
/* weekly discount badge in summary sidebar */
.v2-bm-summary-discount {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.68rem;
  color: rgba(31,74,74,0.85);
  background: rgba(31,74,74,0.15);
  padding: 0.15rem 0.5rem;
  border-radius: 2px;
  text-align: right;
  display: block;
  margin-bottom: 0.2rem;
}
/* inline savings text below price */
.v2-bm-summary-savings {
  font-family: 'Inter', sans-serif;
  font-size: 0.75rem;
  color: rgba(245,239,230,0.5);
  text-align: right;
  display: block;
}

/* form inside modal */
.v2-modal-form .form-group { margin-bottom: 1.2rem; }
.v2-modal-form .form-group label {
  display: block;
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--ink);
  margin-bottom: 0.35rem;
  text-transform: uppercase;
}
.v2-modal-form .form-group label.required::after {
  content: ' *';
  color: var(--terracotta);
  font-weight: 400;
}
.v2-modal-form .form-group input,
.v2-modal-form .form-group textarea,
.v2-modal-form .form-group select {
  width: 100%;
  padding: 0.7rem 0.9rem;
  border: 1px solid rgba(154,143,128,0.35);
  border-radius: 2px;
  font-family: 'Inter', sans-serif;
  font-size: 0.9rem;
  color: var(--ink);
  background: var(--paper);
  box-sizing: border-box;
  transition: border-color 0.2s;
}
.v2-modal-form .form-group input:focus,
.v2-modal-form .form-group textarea:focus {
  outline: none;
  border-color: var(--petrolio);
  background: var(--bone);
}
.v2-modal-form .form-group textarea {
  resize: vertical;
  min-height: 80px;
}
.v2-modal-form .form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}
.v2-cancel-note {
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
  background: rgba(31,74,74,0.07);
  border-left: 2px solid var(--petrolio);
  padding: 0.75rem 1rem;
  border-radius: 0 2px 2px 0;
  margin-bottom: 1.4rem;
  font-family: 'Inter', sans-serif;
  font-size: 0.82rem;
  color: var(--petrolio);
  line-height: 1.55;
}
/* Payment in modal */
.v2-payment-section { margin-bottom: 1.4rem; }
.v2-payment-label {
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--ink);
  margin-bottom: 0.7rem;
  display: block;
}
/* 2-column payment card grid */
.payment-cards-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.6rem;
}
.payment-option-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: var(--paper);
  border: 1px solid rgba(154,143,128,0.22);
  border-radius: 3px;
  padding: 0.85rem 1rem;
  cursor: pointer;
  transition: border-color 0.2s, background 0.2s;
  position: relative;
}
.payment-option-card:hover {
  border-color: rgba(154,143,128,0.5);
}
.payment-option-card.selected {
  border: 2px solid var(--ink);
  background: var(--bone);
}
.payment-option-card input[type="radio"] {
  position: absolute;
  opacity: 0;
  width: 0; height: 0;
}
.pay-card-inner {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.pay-card-text {}
.pay-title {
  font-family: 'Inter', sans-serif;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 0.2rem;
}
.pay-desc {
  font-family: 'Inter', sans-serif;
  font-size: 0.75rem;
  color: var(--stone);
  line-height: 1.5;
}
.pay-check-icon {
  display: none;
  color: var(--ink);
  flex-shrink: 0;
  margin-top: 1px;
}
.payment-option-card.selected .pay-check-icon {
  display: block;
}
/* Submit button in sidebar — hidden from form area */
.v2-bm-submit-area { display: none; }
/* Sidebar CTA */
.v2-bm-sidebar-cta {
  margin-top: 1.4rem;
}
.btn-sidebar-confirm {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  width: 100%;
  padding: 1rem;
  border: none;
  border-radius: 3px;
  background: #6b7c3a;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
  margin-bottom: 0.7rem;
}
.btn-sidebar-confirm:hover { background: #5a6930; transform: translateY(-1px); }
.btn-sidebar-confirm:disabled { opacity: 0.45; cursor: not-allowed; transform: none; }
.btn-sidebar-back {
  display: block;
  width: 100%;
  background: none;
  border: none;
  color: rgba(245,239,230,0.6);
  font-family: 'Inter', sans-serif;
  font-size: 0.8rem;
  text-align: center;
  cursor: pointer;
  padding: 0.3rem;
  letter-spacing: 0.02em;
  transition: color 0.2s;
}
.btn-sidebar-back:hover { color: var(--bone); }
/* Success */
.booking-success-msg {
  display: none;
  text-align: center;
  padding: 3rem 2rem;
}
.booking-success-msg.active { display: block; }
.booking-success-msg .success-icon {
  font-size: 2.5rem;
  margin-bottom: 1rem;
}
.booking-success-msg h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.8rem;
  font-weight: 500;
  color: var(--petrolio);
  margin-bottom: 0.6rem;
}
.booking-success-msg p {
  font-family: 'Inter', sans-serif;
  font-size: 0.92rem;
  color: var(--stone);
  max-width: 380px;
  margin: 0 auto 1.6rem;
  line-height: 1.65;
}
.btn-success-wa {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.85rem 2rem;
  background: #25D366;
  color: #fff;
  border-radius: 2px;
  font-family: 'Inter', sans-serif;
  font-size: 0.9rem;
  font-weight: 600;
  text-decoration: none;
  transition: background 0.2s;
  width: 100%;
  max-width: 340px;
  margin-bottom: 0.6rem;
}
.btn-success-wa:hover { background: #1ebe59; }

/* ── Modal nav buttons ────────────────────────────────── */
.v2-bm-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.2rem 2rem;
  border-top: 1px solid rgba(154,143,128,0.15);
  background: var(--bone);
  position: sticky;
  bottom: 0;
}
.v2-bm-nav-back {
  font-family: 'Inter', sans-serif;
  font-size: 0.82rem;
  font-weight: 500;
  color: var(--stone);
  background: none;
  border: 1px solid rgba(154,143,128,0.3);
  border-radius: 2px;
  padding: 0.6rem 1.2rem;
  cursor: pointer;
  transition: color 0.2s, border-color 0.2s;
  letter-spacing: 0.03em;
}
.v2-bm-nav-back:hover { color: var(--ink); border-color: var(--ink); }
.v2-bm-nav-next {
  font-family: 'Inter', sans-serif;
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--bone);
  background: var(--ink);
  border: none;
  border-radius: 2px;
  padding: 0.7rem 1.8rem;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
  letter-spacing: 0.04em;
}
.v2-bm-nav-next:hover { background: var(--petrolio); transform: translateY(-1px); }
.v2-bm-nav-next:disabled { opacity: 0.35; cursor: not-allowed; transform: none; background: var(--stone); }
.v2-bm-nav-wa {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  color: var(--stone);
  text-decoration: none;
  transition: color 0.2s;
}
.v2-bm-nav-wa:hover { color: #25D366; }
/* error */
.v2-bm-error {
  font-family: 'Inter', sans-serif;
  font-size: 0.82rem;
  color: var(--terracotta);
  margin-top: 0.6rem;
  display: none;
}
.v2-bm-error.show { display: block; }

/* ── Responsive ───────────────────────────────────────── */
@media (max-width: 900px) {
  .pren-guarantees-grid { grid-template-columns: repeat(2, 1fr); }
  .pren-how-steps { grid-template-columns: 1fr; gap: 2rem; }
  .v2-bm-step1-grid { grid-template-columns: 1fr; }
  .v2-bm-stay-panel { position: static; }
  .v2-bm-rooms-grid { grid-template-columns: 1fr; }
  .v2-bm-step3-grid { grid-template-columns: 1fr; }
  .v2-bm-summary-side { position: static; }
}
@media (max-width: 640px) {
  .pren-guarantees-grid { grid-template-columns: 1fr; }
  .pren-hero { padding: 5rem 0 4rem; }
  .v2-bm-card { max-height: 100vh; border-radius: 0; }
  .v2-bm-overlay { padding: 0; align-items: flex-end; }
  .v2-bm-rail-label { display: none; }
  .v2-modal-form .form-row { grid-template-columns: 1fr; }
}

/* hidden inputs (kept for JS compat) */
#search-checkin, #search-checkout, #search-guests { display: none; }
#max-nights-error { display: none !important; }
</style>

<!-- Structured Data: FAQ Prenotazione -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Conviene prenotare direttamente su Casa e Bottega?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sì, prenotando direttamente su casaebottegapuglia.it risparmi il 20% rispetto al prezzo su Booking.com o Airbnb. La tariffa diretta è la più conveniente disponibile."
      }
    },
    {
      "@type": "Question",
      "name": "Quali metodi di pagamento accetta Casa e Bottega?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Casa e Bottega accetta pagamenti tramite PayPal oppure in contanti/carta al momento del soggiorno. Per prenotazioni dirette sono disponibili entrambe le opzioni."
      }
    },
    {
      "@type": "Question",
      "name": "Posso portare bambini a Casa e Bottega?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Casa e Bottega ospita fino a 2 persone per camera. Per La Dimora è disponibile un letto extra su richiesta. Contattaci per maggiori informazioni sulle esigenze specifiche."
      }
    },
    {
      "@type": "Question",
      "name": "Quanto costa una notte a Casa e Bottega Manfredonia?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le tariffe variano in base alla stagione e alla camera. Prenotando direttamente si risparmia il 20% rispetto ai portali OTA. Consulta il calendario disponibilità per vedere i prezzi aggiornati."
      }
    },
    {
      "@type": "Question",
      "name": "È possibile annullare la prenotazione?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le condizioni di cancellazione vengono comunicate al momento della prenotazione. Scrivi a booking@casaebottegapuglia.it per informazioni sulle politiche di cancellazione."
      }
    }
  ]
}
</script>
